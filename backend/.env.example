# Local dev: SQLite, zero install required.
# Deploy (VPS): swap to Postgres, e.g.
#   DATABASE_URL=postgresql+psycopg://user:password@host:5432/logicopilot
# then run `uv run alembic upgrade head` against it. No model/migration changes needed.
DATABASE_URL=sqlite:///./logicopilot.db

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173

# Set to true only when serving over HTTPS (production).
COOKIE_SECURE=false
